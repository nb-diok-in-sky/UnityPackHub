{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    {
      "identifier": "fs:allow-stat",
      "allow": [{ "path": "**" }]
    },
    {
      "identifier": "fs:read-all",
      "allow": [{ "path": "**" }]
    },
    {
      "identifier": "fs:write-all",
      "allow": [{ "path": "**" }]
    },
    "shell:default",
    "shell:allow-execute",
    "shell:allow-open",
    "http:default",
    "http:allow-fetch",
    "http:allow-fetch-cancel",
    "http:allow-fetch-read-body",
    "http:allow-fetch-send"
  ]
}
